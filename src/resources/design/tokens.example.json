{
  "unit": "rem",
  "page": {
    "backgroundColor": "white",
    "margin": 0,
    "padding": 0
  },
  "colors": [
    {
      "type": "black",
      "color": "#161616",
      "shades": []
    },
    {
      "type": "highlight-black",
      "color": "#212121",
      "shades": []
    },
    {
      "type": "white",
      "color": "#fff",
      "shades": []
    },
    {
      "type": "white-muted",
      "color": "rgba(255, 255, 255, 0.6)",
      "shades": []
    },
    {
      "type": "bright-green-100",
      "color": "rgb(146, 191, 48)",
      "shades": [20, 30]
    },
    {
      "type": "bright-green-60",
      "color": "rgba(146, 191, 48, 0.6)",
      "shades": [20, 30]
    },
    {
      "type": "bright-green-40",
      "color": "rgba(146, 191, 48, 0.4)",
      "shades": [20, 30]
    }
  ],
  "fonts": [
    {
      "type": "main-text-regular",
      "uri": "'../fonts/freesans'",
      "sizes": ["0.75rem", "0.875rem", "1rem", "1.125rem", "1.25rem"]
    },
    {
      "type": "main-text-bold",
      "uri": "'../fonts/freesansbold'",
      "sizes": ["0.75rem", "0.875rem", "1rem", "1.125rem", "1.25rem"]
    },
    {
      "type": "main-text-link",
      "uri": "'../fonts/freesansbold'",
      "sizes": ["0.75rem", "0.875rem", "1rem"]
    },
    {
      "type": "label-text",
      "uri": "'../fonts/freesans'",
      "sizes": [
        "0.75rem",
        "0.875rem",
        "1rem",
        "1.125rem",
        "1.25rem",
        "1.375rem",
        "1.5rem",
        "1.625rem",
        "1.75rem"
      ]
    }
  ],
  "headings": {
    "type": "heading",
    "uri": "'../fonts/freesansbold'",
    "variant": [
      {
        "h1": "2.625rem"
      },
      {
        "h2": "2rem"
      },
      {
        "h3": "1.75rem"
      },
      {
        "h4": "1.625rem"
      },
      {
        "h5": "1.5rem"
      },
      {
        "h6": "1.375rem"
      }
    ]
  },
  "spacing": {
    "small": 1,
    "medium": 2,
    "large": 3
  },
  "borderRadius": {
    "small": 4,
    "medium": 8,
    "large": 12
  },
  "boxShadow": {
    "light": "0px 1px 3px rgba(0, 0, 0, 0.2)",
    "medium": "0px 4px 6px rgba(0, 0, 0, 0.3)",
    "heavy": "0px 10px 20px rgba(0, 0, 0, 0.4)"
  },
  "semanticColors": {
    "success": "#2e7d32",
    "warning": "#ed6c02",
    "danger": "#d32f2f",
    "info": "#0288d1"
  },
  "zIndex": {
    "base": 0,
    "dropdown": 100,
    "sticky": 200,
    "modal": 1000,
    "toast": 1100
  },
  "opacity": {
    "disabled": 0.4,
    "muted": 0.64,
    "overlay": 0.72
  },
  "forms": {
    "input": {
      "height": "2.5rem",
      "padding-x": "0.75rem",
      "padding-y": "0.5rem",
      "border": "1px solid #d0d0d0",
      "border-bottom": "1px solid #d0d0d0",
      "border-radius": "0.5rem",
      "background-color": "#fff",
      "text-color": "#161616",
      "placeholder-color": "rgba(0, 0, 0, 0.45)"
    },
    "focus": {
      "border": "1px solid #0288d1",
      "border-bottom": "1px solid #0288d1",
      "outline-color": "rgba(2, 136, 209, 0.32)",
      "outline-width": "0.1875rem"
    },
    "disabled": {
      "background-color": "#f0f0f0",
      "border": "1px solid #d8d8d8",
      "border-bottom": "1px solid #d8d8d8",
      "text-color": "rgba(0, 0, 0, 0.45)"
    },
    "error": {
      "border": "1px solid #d32f2f",
      "border-bottom": "1px solid #d32f2f",
      "text-color": "#d32f2f"
    }
  }
}
